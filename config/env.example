# Dietician backend environment variables — copy to /etc/dietician/env on VPS
# and fill secrets. Council 1779188964 R2 marks Resend/OpenRouter/Rclone as
# STUB-OK for the tracer-bullet first deploy; leave those keys blank to let
# the corresponding routes 503 / use NoopEmailSender / skip cron rather than
# crashing the JVM. See docs/runbooks/first-vps-deploy.md.
#
# Naming convention: DIETICIAN_* namespace throughout, per the docstring
# contract on `server/src/main/kotlin/.../db/DatabaseFactory.kt`. The DB
# password preferred path is the tmpfs file `/run/dietician-keys/db.passphrase`
# (mode 0600 dietician); DIETICIAN_DB_PASSWORD here is the env-fallback used
# only when tmpfs is unmounted.

# ============================================================================
# Network bind (canonical: Main.kt::TailnetDiscovery → `tailscale ip -4`)
# ============================================================================
# DIETICIAN_HOST_OVERRIDE=                # Optional — bypass tailscale discovery (dev/CI)
DIETICIAN_PORT=8081
DIETICIAN_METRICS_PORT=9091

# ============================================================================
# Postgres (canonical store)
# ============================================================================
DIETICIAN_DB_URL=jdbc:postgresql://127.0.0.1:5432/dietician
DIETICIAN_DB_USER=dietician
# DIETICIAN_DB_PASSWORD=                  # Prefer tmpfs path; set here only as fallback

# ============================================================================
# LLM router (STUB-OK for tracer-bullet — blank → llmAdaptersOnlyModule;
# Coach route returns 503 stub)
# ============================================================================
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ============================================================================
# Magic-link email (STUB-OK for tracer-bullet — blank → NoopEmailSender logs
# the token at INFO; operator greps it from /opt/dietician/logs/backend.log)
# ============================================================================
RESEND_API_KEY=
DIETICIAN_MAIL_FROM=                     # Default: onboarding@resend.dev when blank
DIETICIAN_MAGIC_LINK_BASE=               # Default: https://dietician.local/auth/magic-link

# ============================================================================
# In-JVM cron (Plan-3 RC4 — disable for tracer-bullet to skip backup/audit)
# ============================================================================
DIETICIAN_DISABLE_INJVM_CRONS=true       # Set false once rclone OneDrive-crypt is configured

# ============================================================================
# Backup target (used by BackupCron when crons enabled; per spec §A18)
# ============================================================================
DIETICIAN_BACKUP_REMOTE=onedrive-crypt:dietician-backups
# RCLONE_CONFIG_PASS_FILE=/run/dietician-keys/rclone.passphrase

# ============================================================================
# Adjacent services (canonical Tailnet addresses — leave as-is for prod)
# ============================================================================
NTFY_URL=http://100.101.47.77:8082
GROBID_URL=http://100.80.132.115:8083    # GROBID lives on desktop (dell-g5)

LOG_LEVEL=INFO
